# Required secrets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
FMP_API_KEY=

# Safety
PAPER=true
ENABLE_TRADING=false

# Universe and strategy
WATCHLIST=QQQ,SMH,NVDA,AVGO,AMD,MU,MSFT,GOOGL,META,AMZN,ORCL,SPY
# Multiple symbols are evaluated before selecting a trade.
STRATEGY=disabled
# STRATEGY options: disabled, manual_once, sma_trend, intraday_swing
SYMBOL_SELECTION_METHOD=best_signal
# SYMBOL_SELECTION_METHOD options: best_signal, first_signal

# Alpaca market data feed.
# Basic/free plans usually use iex; paid plans may use sip.
DATA_FEED=iex
MARKET_SYMBOL=QQQ

# Risk model
RISK_FRACTION=0.001
REWARD_RISK_RATIO=3.0
STOP_LOSS_PCT=0.03
ALLOW_FRACTIONAL=false
MAX_POSITION_COUNT=1

# Earnings guard
EARNINGS_BLOCK_DAYS_BEFORE=1
EARNINGS_BLOCK_DAYS_AFTER=1

# Manual blackout file
MANUAL_BLACKOUT_FILE=config/manual_blackout_events.csv

# SMA sample strategy
SMA_FAST=20
SMA_SLOW=50
HISTORICAL_LOOKBACK_DAYS=180

# Intraday swing strategy
INTRADAY_TIMEFRAME=2Hour
DAILY_FAST=20
DAILY_SLOW=100
INTRADAY_SMA=20
BREAKOUT_LOOKBACK=5

# Backtest
BACKTEST_START=2025-01-01
BACKTEST_END=2025-12-31
BACKTEST_END_MODE=window
BACKTEST_INITIAL_EQUITY=10000

# Optional debug
LOG_LEVEL=INFO
