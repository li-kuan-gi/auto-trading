# Required secrets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
FMP_API_KEY=

# Safety
PAPER=true
ENABLE_TRADING=false

# Universe and strategy
WATCHLIST=SPY
# Multiple symbols are evaluated before selecting a trade. Example: WATCHLIST=AAPL,SPY
STRATEGY=disabled
# STRATEGY options: disabled, manual_once, sma_trend
SYMBOL_SELECTION_METHOD=best_signal
# SYMBOL_SELECTION_METHOD options: best_signal, first_signal

# Alpaca market data feed.
# Basic/free plans usually use iex; paid plans may use sip.
DATA_FEED=iex

# Risk model
RISK_FRACTION=0.01
REWARD_RISK_RATIO=2.0
STOP_LOSS_PCT=0.05
ALLOW_FRACTIONAL=false
MAX_POSITION_COUNT=1

# Earnings guard
EARNINGS_BLOCK_DAYS_BEFORE=1
EARNINGS_BLOCK_DAYS_AFTER=1

# Manual blackout file
MANUAL_BLACKOUT_FILE=config/manual_blackout_events.csv

# SMA sample strategy
SMA_FAST=20
SMA_SLOW=50
HISTORICAL_LOOKBACK_DAYS=180

# Optional debug
LOG_LEVEL=INFO
